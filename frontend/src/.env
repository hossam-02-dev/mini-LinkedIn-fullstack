# ============================================
# API Configuration
# ============================================
REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_API_BASE_URL=http://localhost:8080

# ============================================
# WebSocket Configuration (pour notifications en temps réel)
# ============================================
REACT_APP_WS_URL=ws://localhost:8080/ws
REACT_APP_WS_NOTIFICATIONS=/topic/notifications

# ============================================
# Authentication
# ============================================
REACT_APP_TOKEN_KEY=accessToken
REACT_APP_REFRESH_TOKEN_KEY=refreshToken
REACT_APP_USER_KEY=user

# ============================================
# Application Configuration
# ============================================
REACT_APP_APP_NAME=ProfNetwork
REACT_APP_VERSION=1.0.0
REACT_APP_ENV=development

# ============================================
# Pagination (valeurs par défaut)
# ============================================
REACT_APP_DEFAULT_PAGE_SIZE=10
REACT_APP_FEED_PAGE_SIZE=20
REACT_APP_COMMENTS_PAGE_SIZE=10

# ============================================
# Upload Configuration
# ============================================
REACT_APP_MAX_IMAGE_SIZE=5242880
REACT_APP_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ============================================
# Timeouts (en millisecondes)
# ============================================
REACT_APP_API_TIMEOUT=30000
REACT_APP_NOTIFICATION_INTERVAL=30000

# ============================================
# Feature Flags
# ============================================
REACT_APP_ENABLE_WEBSOCKET=true
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_MESSAGING=true